# Resend API Key — get this from resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The "From" address — must match your verified domain in Resend
# For a quick start you can use: onboarding@resend.dev (Resend's shared domain, no DNS setup needed)
# For production use: docs@simonexpress.com (requires DNS verification in Resend dashboard)
FROM_EMAIL=docs@simonexpress.com

# The billing email to send all submissions to
TO_EMAIL=billing@simonexpress.com

# Fuel data upload security key (set this to any random secret string)
FUEL_API_KEY=your-secret-key-here

# Google Maps API key for route planner and map
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-api-key
